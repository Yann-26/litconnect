// ═══════════════════════════════════════════════════════════
//  storage.rules — LitConnect / Invertis University
//
//  These rules ALLOW uploads from anonymous auth sessions.
//  Deploy with:  firebase deploy --only storage
// ═══════════════════════════════════════════════════════════

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Application document uploads ──
    // Path: applications/{appId}/{filename}
    match /applications/{appId}/{filename} {

      // ✅ Any signed-in user (anonymous OK) can upload
      //    • File ≤ 5 MB
      //    • Must be a PDF or image type
      allow write: if request.auth != null
        && request.resource.size <= 5 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
          || request.resource.contentType == 'application/octet-stream'
        );

      // ✅ Any signed-in user can read (needed for getDownloadURL)
      allow read: if request.auth != null;

      // ❌ Nobody can delete
      allow delete: if false;
    }

    // Block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}



